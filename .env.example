# ===========================================
# Smart-Watch-Display Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartwatch

# Application Port
PORT=3001

# Node Environment
NODE_ENV=production

# Frontend Base Path (for routing)
BASE_PATH=/

# API URL (for frontend to call backend)
API_URL=http://localhost:3001

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production

# ===========================================
# Admin Credentials (REQUIRED)
# ===========================================
# Admin username for dashboard login
ADMIN_USERNAME=admin

# Admin email for dashboard login
ADMIN_EMAIL=admin@cib.com

# Admin password - CHANGE THIS IMMEDIATELY!
# This password will be hashed and stored in the database
ADMIN_PASSWORD=YourSecurePassword123!

# Logging
LOG_LEVEL=info
